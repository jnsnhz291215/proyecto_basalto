# ===========================================
# ARCHIVO DE CONFIGURACIÓN - BASALTO DRILLING
# ===========================================
# Copia este archivo como ".env" y completa con tus valores reales

# ========== BASE DE DATOS ==========
# Para DOCKER: usa los valores que están en docker-compose.yml
# Para LOCAL: configura tu MySQL/MariaDB local

# Docker (valores por defecto del docker-compose.yml)
DB_HOST=db-basalto          # Para Docker, usa el nombre del servicio
# DB_HOST=localhost         # Para desarrollo local, descomenta esta línea

DB_PORT=3306                # Puerto interno (siempre 3306)
DB_USER=juan_admin          # Usuario configurado en docker-compose
DB_PASSWORD=basalto_password  # Password configurado en docker-compose
DB_NAME=basalto_test        # Base de datos configurada en docker-compose

# ========== SERVIDOR ==========
PORT=3000                   # Puerto de la aplicación

# ========== GENERACIÓN AUTOMÁTICA DE INSTANCIAS ==========
AUTO_GENERATE_INSTANCES=true    # true/false - Genera turnos automáticamente al iniciar
AUTO_GENERATE_FORCE_REBUILD=false  # true/false - Fuerza regeneración completa

# ========== EMAIL (SMTP) ==========
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_email@gmail.com
SMTP_PASSWORD=tu_app_password_aqui   # Usa "App Password" de Google, no tu contraseña
SMTP_FROM=noreply@basaltodrilling.cl
